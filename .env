# ============================================================
# bmqa-v2 — .env.example
# انسخ هذا الملف إلى ".env" واملأ القيم الحقيقية.
# لا تضع أي قيمة حقيقية هنا أو في أي ملف يُرفع إلى Git.
# ============================================================

# --- Telegram Bot (إلزامي) ---
BOT_TOKEN=
SUDO_ID=
BOT_USERNAME=

# --- Pyrogram / Telegram API credentials (إلزامي) ---
API_ID=
API_HASH=

# --- Userbot session قديم (غير مستخدم حالياً، اتركه فارغاً) ---
USERBOT_SESSION_STRING=

# --- ARQ API (اختياري) ---
ARQ_API_KEY=
ARQ_API_URL=https://arq.hamker.dev

# --- Redis (إلزامي لتشغيل البوت والـ worker) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- kvsqlite databases (اختياري، لها قيم افتراضية) ---
YTDB_PATH=ytdb.sqlite
SOUNDDB_PATH=sounddb.sqlite
WSDB_PATH=wsdb.sqlite

# ============================================================
# ميزة تشغيل الصوت في المكالمات (اختيارية بالكامل)
# اتركها جميعاً فارغة لتعطيل الميزة كلياً دون أي أثر على بقية البوت.
# ============================================================

# جلسة Pyrogram لحساب Userbot مساعد (session string). فارغ = الميزة معطّلة.
ASSISTANT_SESSION=

# تفعيل تشغيل الفيديو في المكالمة (افتراضي: false = صوت فقط)
VC_VIDEO_ENABLED=false

# الحد الأقصى لمدة أي مقطع بالدقائق (افتراضي: 60)
VC_DURATION_LIMIT_MINUTES=60

# رابط ArtistBots API لتنزيل الصوت
API_URL=

# رابط ArtistBots API لتنزيل الفيديو (قد يطابق API_URL أو مضيفاً مختلفاً)
VIDEO_API_URL=

# مفاتيح ArtistBots مفصولة بفواصل، مثال: key1,key2,key3
# (أو استخدم API_KEY لمفتاح واحد فقط كتوافق قديم)
API_KEYS=
API_KEY=
