# ============================================================
# انسخ هذا الملف باسم .env للتطوير المحلي فقط.
# على Railway: لا تستخدم .env إطلاقاً — بل ضع نفس الأسماء في
# تبويب Variables لكل Service (بوت + worker).
# ============================================================

# --- Telegram Bot (إلزامية) ---
BOT_TOKEN=
SUDO_ID=
API_ID=
API_HASH=
BOT_USERNAME=

# --- Userbot session (اختياري) ---
USERBOT_SESSION_STRING=

# --- ARQ API خارجي (اختياري) ---
ARQ_API_KEY=
ARQ_API_URL=https://arq.hamker.dev

# --- Redis (إلزامية عملياً؛ فعّل إضافة Redis من Railway واستخرج القيم منها) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- kvsqlite (اتركها كما هي إلا لو ربطت Volume بمسار مختلف) ---
YTDB_PATH=ytdb.sqlite
SOUNDDB_PATH=sounddb.sqlite
WSDB_PATH=wsdb.sqlite

# --- اختياري ---
LOG_DIR=logs
DOWNLOAD_DIR=downloads
